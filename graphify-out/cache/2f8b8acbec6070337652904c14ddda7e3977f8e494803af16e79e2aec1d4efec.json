Mode,\n        ...(bootstrap ? { bootstrap } : {}),\n        createdAt: messageCreatedAt,\n      });\n      turnStartSucceeded = true;\n    })", "source_file": "references/t3code/apps/web/src/components/ChatView.tsx", "source_location": "L2581"}, {"caller_nid": "chatview_onsend", "callee": "resetLocalDispatch", "source_file": "references/t3code/apps/web/src/components/ChatView.tsx", "source_location": "L2715"}, {"caller_nid": "chatview_oninterrupt", "callee": "readEnvironmentApi", "source_file": "references/t3code/apps/web/src/components/ChatView.tsx", "source_location": "L2720"}, {"caller_nid": "chatview_oninterrupt", "callee": "dispatchCommand", "source_file": "references/t3code/apps/web/src/components/ChatView.tsx", "source_location": "L2722"}, {"caller_nid": "chatview_oninterrupt", "callee": "newCommandId", "source_file": "references/t3code/apps/web/src/components/ChatView.tsx", "source_location": "L2724"}, {"caller_nid": "chatview_oninterrupt", "callee": "toISOString", "source_file": "references/t3code/apps/web/src/components/ChatView.tsx", "source_location": "L2726"}]}