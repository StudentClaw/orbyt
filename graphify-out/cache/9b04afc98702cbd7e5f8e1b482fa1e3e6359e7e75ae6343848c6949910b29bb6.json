nt-claw/packages/ui/src/rpc/assignmentDetailState.ts", "source_location": "L246"}, {"caller_nid": "assignmentdetailstate_resetassignmentdetailstatefortests", "callee": "clear", "source_file": "/Users/rereynrd/School/student-claw/packages/ui/src/rpc/assignmentDetailState.ts", "source_location": "L251"}, {"caller_nid": "assignmentdetailstate_resetassignmentdetailstatefortests", "callee": "set", "source_file": "/Users/rereynrd/School/student-claw/packages/ui/src/rpc/assignmentDetailState.ts", "source_location": "L252"}]}