# Orbyt environment variables
# Copy to `.env` (or `.env.local`) at the repo root and fill in as needed.
# All variables are optional — Orbyt picks safe defaults when they are unset.

# --- Codex (AI runtime) ---------------------------------------------------
# Path to the codex CLI binary if it isn't bundled or on PATH.
CODEX_BINARY_PATH=
# Default model id Codex should use.
CODEX_MODEL=
# Codex request timeout in milliseconds.
CODEX_REQUEST_TIMEOUT_MS=

# --- Local data -----------------------------------------------------------
# Override the SQLite database path. Defaults to <userData>/orbyt.db.
DB_PATH=
# Override Orbyt's home directory (memory graph, push settings, etc.).
ORBYT_HOME=
# Override the bundled skills staging directory used in dev.
ORBYT_BUNDLED_SKILLS_DIR=

# --- Dev convenience ------------------------------------------------------
# Set to "development" for verbose logging; "production" for builds.
NODE_ENV=
# Open Electron devtools on launch when set to "1".
ORBYT_DEBUG_WINDOW=

# --- Standalone UI dev mode (bun run dev:standalone) ----------------------
# Used by packages/ui when running outside Electron against a remote server.
VITE_STANDALONE_WS_URL=
VITE_STANDALONE_WS_AUTH_TOKEN=
VITE_STANDALONE_APP_VERSION=
VITE_STANDALONE_PLATFORM=
